# API gateway
PORT=3000

# AI gateway
# PORT=3010

# Postgres (docker-compose defaults) — Prisma expects postgresql:// or postgres://
DATABASE_URL=postgresql://venext:venext@localhost:5432/venext

# Core domain API (Prisma)
# PORT=3200

# Redis
REDIS_URL=redis://localhost:6379

# Mapbox (industrial web)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Yellika SMS — OTP terrain (https://panel.yellikasms.com/developers/docs)
YELLIKA_SMS_BASE_URL=https://panel.yellikasms.com
YELLIKA_SMS_TOKEN=
YELLIKA_SMS_SENDER_ID=
YELLIKA_SMS_CONNECT_TIMEOUT_MS=5000
YELLIKA_SMS_READ_TIMEOUT_MS=10000
SMS_OTP_PRODUCT_NAME=VENEXT
