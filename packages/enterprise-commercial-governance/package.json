{
  "name": "enterprise-commercial-governance",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "separation": ["./dist/separation.d.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./separation": {
      "types": "./dist/separation.d.ts",
      "import": "./dist/separation.js",
      "require": "./dist/separation.js",
      "default": "./dist/separation.js"
    },
    "./storage": {
      "types": "./dist/enterprise-governance-storage.d.ts",
      "import": "./dist/enterprise-governance-storage.js"
    },
    "./history": {
      "types": "./dist/enterprise-governance-history.d.ts",
      "import": "./dist/enterprise-governance-history.js"
    },
    "./security-alerts": {
      "types": "./dist/enterprise-security-alerts.d.ts",
      "import": "./dist/enterprise-security-alerts.js"
    },
    "./styles.css": "./src/enterprise-governance.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "commerce-foundation-guardrails": "file:../commerce-foundation-guardrails",
    "commerce-performance-foundation": "file:../commerce-performance-foundation"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
