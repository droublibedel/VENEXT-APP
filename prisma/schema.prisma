// -----------------------------------------------------------------------------
// Instruction BACKOFFICE-01-B — enterprise governance live (grands comptes)
// -----------------------------------------------------------------------------

model EnterpriseCommercialChannelRecord {
  enterpriseId         String   @id
  accountSegment       String   @default("LARGE_ACCOUNTS")
  actorKind            String
  contractReference    String
  companyName          String
  headquarters         String   @default("")
  governanceStatus     String
  activationStatus     String
  onboardingProgress   Int      @default(0)
  status               String   @default("ACTIVE")
  archivedAt           DateTime?
  archivedReason       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  poleActivations      EnterprisePoleActivationRecord[]
  invitations          EnterpriseInvitationRecord[]
  collaborators        EnterpriseCollaboratorRecord[]
  trustedDevices       EnterpriseTrustedDeviceRecord[]
  securityAlerts       EnterpriseSecurityAlertRecord[]
  governanceHistory    EnterpriseGovernanceHistoryRecord[]
  contractDocuments    EnterpriseContractDocumentRecord[]

  @@index([governanceStatus, status])
  @@index([archivedAt])
  @@map("enterprise_commercial_channels")
}

model EnterprisePoleActivationRecord {
  id               String   @id @default(uuid()) @db.Uuid
  enterpriseId     String
  poleId           String
  poleLabel        String
  activated        Boolean  @default(true)
  secureSlug       String   @default("")
  privateUrl       String   @default("")
  activationCode   String?
  collaboratorEmail String?
  status           String   @default("ACTIVE")
  archivedAt       DateTime?
  archivedReason   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  channel          EnterpriseCommercialChannelRecord @relation(fields: [enterpriseId], references: [enterpriseId], onDelete: Restrict)

  @@unique([enterpriseId, poleId])
  @@index([enterpriseId, status])
  @@map("enterprise_pole_activations")
}

model EnterpriseInvitationRecord {
  token            String   @id
  enterpriseId     String
  poleId           String
  poleLabel        String
  activationCode   String
  status           String   @default("PENDING")
  expiresAt        DateTime?
  revokedAt        DateTime?
  archivedAt       DateTime?
  archivedReason   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  channel          EnterpriseCommercialChannelRecord @relation(fields: [enterpriseId], references: [enterpriseId], onDelete: Restrict)

  @@index([enterpriseId, status])
  @@map("enterprise_invitations")
}

model EnterpriseCollaboratorRecord {
  internalEnterpriseUserId String   @id
  enterpriseId             String
  poleId                   String
  firstName                String
  lastName                 String
  phone                    String
  email                    String
  status                   String   @default("PENDING_VALIDATION")
  archivedAt               DateTime?
  archivedReason           String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  channel                  EnterpriseCommercialChannelRecord @relation(fields: [enterpriseId], references: [enterpriseId], onDelete: Restrict)

  @@index([enterpriseId, status])
  @@map("enterprise_collaborators")
}

model EnterpriseTrustedDeviceRecord {
  id               String   @id @default(uuid()) @db.Uuid
  enterpriseId     String
  deviceLabel      String
  machineFingerprint String?
  status           String   @default("PENDING")
  archivedAt       DateTime?
  archivedReason   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  channel          EnterpriseCommercialChannelRecord @relation(fields: [enterpriseId], references: [enterpriseId], onDelete: Restrict)

  @@index([enterpriseId, status])
  @@map("enterprise_trusted_devices")
}

model EnterpriseSecurityAlertRecord {
  id             String   @id @default(uuid()) @db.Uuid
  enterpriseId   String
  alertType      String
  message        String
  severity       String   @default("warning")
  acknowledged   Boolean  @default(false)
  status         String   @default("OPEN")
  archivedAt     DateTime?
  archivedReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channel        EnterpriseCommercialChannelRecord @relation(fields: [enterpriseId], references: [enterpriseId], onDelete: Restrict)

  @@index([enterpriseId, acknowledged, status])
  @@map("enterprise_security_alerts")
}

model EnterpriseGovernanceHistoryRecord {
  id             String   @id @default(uuid()) @db.Uuid
  enterpriseId   String
  action         String
  author         String
  authorLevel    String   @default("VENEXT_GLOBAL")
  target         String
  note           String
  document       String?
  previousState  String
  newState       String
  status         String   @default("RECORDED")
  archivedAt     DateTime?
  archivedReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channel        EnterpriseCommercialChannelRecord @relation(fields: [enterpriseId], references: [enterpriseId], onDelete: Restrict)

  @@index([enterpriseId, createdAt])
  @@map("enterprise_governance_history")
}

model EnterpriseContractDocumentRecord {
  id             String   @id @default(uuid()) @db.Uuid
  enterpriseId   String
  title          String
  kind           String
  fileRef        String
  status         String   @default("ACTIVE")
  archivedAt     DateTime?
  archivedReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channel        EnterpriseCommercialChannelRecord @relation(fields: [enterpriseId], references: [enterpriseId], onDelete: Restrict)

  @@index([enterpriseId, status])
  @@map("enterprise_contract_documents")
}
