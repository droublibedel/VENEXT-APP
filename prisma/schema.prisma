  continuityNode                  RelationalEconomicContinuityNode? @relation(fields: [continuityNodeId], references: [id], onDelete: SetNull)
  macroEconomicNode               RelationalMacroEconomicNode?      @relation(fields: [macroEconomicNodeId], references: [id], onDelete: SetNull)
  supplyFlowNode                  RelationalSupplyFlowNode?         @relation(fields: [supplyFlowNodeId], references: [id], onDelete: SetNull)
  geoZone                         RelationalGeoEconomicZone?      @relation(fields: [geoZoneId], references: [id], onDelete: SetNull)
  sectorNode                      RelationalSectorNode?             @relation(fields: [sectorNodeId], references: [id], onDelete: SetNull)
  strategicMemory                 RelationalStrategicMemory?        @relation(fields: [strategicMemoryId], references: [id], onDelete: SetNull)
  signals                         RelationalMacroObservatoryGovernanceSignal[]
  matrices                        RelationalMacroObservatoryGovernanceMatrix[]
  snapshots                       RelationalMacroObservatoryGovernanceSnapshot[]
  events                          RelationalMacroObservatoryGovernanceEvent[] @relation("MacroObservatoryGovernanceEventNode")

  @@index([relationshipId])
  @@index([macroGovernanceScore], map: "rmog_nodes_macro_governance_score_idx")
  @@index([executiveCoordinationPressure])
  @@index([systemicConcentration])
  @@index([resilienceStrength])
  @@index([territoryCountry])
  @@index([sectorSlug])
  @@index([macroGovernancePriority], map: "rmog_nodes_macro_governance_priority_idx")
  @@index([createdAt])
  @@map("relational_macro_observatory_governance_nodes")
}

model RelationalMacroObservatoryGovernanceSignal {
  id                    String                               @id @default(uuid()) @db.Uuid
  macroObservatoryGovernanceNodeId String                          @db.Uuid
  relationshipId        String                               @db.Uuid
  signalCode            String                               @unique
  signalType            RelationalMacroObservatoryGovernanceSignalType
  intensity             Int                                  @default(0)
  pressureLevel         Int                                  @default(0)
  riskLevel             Int                                  @default(0)
  diagnostics           Json?
  metadata              Json?
  createdAt             DateTime                             @default(now())

  macroObservatoryGovernanceNode RelationalMacroObservatoryGovernanceNode @relation(fields: [macroObservatoryGovernanceNodeId], references: [id], onDelete: Cascade)
  relationship             Relationship                       @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  @@index([macroObservatoryGovernanceNodeId])
  @@index([relationshipId])
  @@index([signalType])
  @@map("relational_macro_observatory_governance_signals")
}

model RelationalMacroObservatoryGovernanceMatrix {
  id                    String                            @id @default(uuid()) @db.Uuid
  macroObservatoryGovernanceNodeId String                       @db.Uuid
  relationshipId        String                            @db.Uuid
  matrixCode            String                            @unique
  matrixType            RelationalMacroObservatoryGovernanceMatrixType
  severity              RelationalMacroObservatoryGovernanceSeverity
