  relationalEconomicMonitoringNodes            RelationalEconomicMonitoringNode[]
  relationalEconomicMonitoringSignals          RelationalEconomicMonitoringSignal[]
  relationalEconomicMonitoringAlerts           RelationalEconomicMonitoringAlert[]
