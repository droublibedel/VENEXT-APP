/**
 * Instruction 18.3 — industrial economic scenario projection (deterministic, snapshot-grounded; not a financial simulator).
 */
model EconomicScenario {
  id                        String   @id @default(cuid())
  organizationId            String   @db.Uuid
  scenarioCode              String
  scenarioType              String
  triggerType               String
  severity                  String
  sourcePole                String
