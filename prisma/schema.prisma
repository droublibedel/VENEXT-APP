  requestState                  SponsoredRelationshipRequestState @default(SUBMITTED)
  motivation                    String?
  createdAt                     DateTime                          @default(now())
  updatedAt                     DateTime                          @updatedAt

  window    SponsoredConversationWindow @relation(fields: [sponsoredConversationWindowId], references: [id], onDelete: Cascade)
  requester Organization                @relation("SponsoredRelReqRequesterOrg", fields: [requesterOrganizationId], references: [id], onDelete: Cascade)
  target    Organization                @relation("SponsoredRelReqTargetOrg", fields: [targetOrganizationId], references: [id], onDelete: Cascade)

  @@index([sponsoredConversationWindowId])
  @@map("sponsored_relationship_requests")
}

model SponsoredExposureAnalytics {
  id                    String   @id @default(uuid()) @db.Uuid
  /**
   * Instruction 20.2A — stable key for upsert (campaign + geo + actor + day + event).
   */
  aggregationKey        String   @unique
  sponsorOrganizationId String   @db.Uuid
  campaignId            String   @db.Uuid
  region                String?
  city                  String?
  district              String?
  /**
