  @@index([read, priority, createdAt])
  @@map("backoffice_internal_notifications")
}

model BackofficeOperationalStreamEventRecord {
  id             String                    @id @default(uuid()) @db.Uuid
  kind           BackofficeStreamEventKind
  title          String
  payload        Json                      @default("{}")
  application    String?
  enterpriseId   String?
  userId         String?
  archivedAt     DateTime?
