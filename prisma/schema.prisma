  title                 String                            @db.VarChar(400)
  summary               String                            @db.VarChar(4000)
  institutionalPressure Int                               @default(0)
  executiveCoordinationPressure Int                               @default(0)
  diagnostics           Json?
  metadata              Json?
  createdAt             DateTime                          @default(now())

  macroObservatoryGovernanceNode RelationalMacroObservatoryGovernanceNode @relation(fields: [macroObservatoryGovernanceNodeId], references: [id], onDelete: Cascade)
  relationship             Relationship                     @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  @@index([macroObservatoryGovernanceNodeId])
  @@index([relationshipId])
  @@index([matrixType])
  @@index([severity])
  @@map("relational_macro_observatory_governance_matrices")
}

model RelationalMacroObservatoryGovernanceSnapshot {
  id                    String                            @id @default(uuid()) @db.Uuid
  relationshipId        String                            @db.Uuid
  macroObservatoryGovernanceNodeId String?                      @db.Uuid
  snapshotCode          String                            @unique
  macroGovernanceStatus RelationalMacroObservatoryGovernanceStatus
  macroGovernanceScore  Int
  executiveCoordinationPressure Int
  systemicConcentration Int
  resilienceStrength    Int
  diagnostics           Json?
  metadata              Json?
  archivedAt            DateTime?
  createdAt             DateTime                          @default(now())

  relationship             Relationship                  @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  macroObservatoryGovernanceNode RelationalMacroObservatoryGovernanceNode? @relation(fields: [macroObservatoryGovernanceNodeId], references: [id], onDelete: SetNull)

  @@index([relationshipId])
  @@index([macroGovernanceScore])
  @@index([executiveCoordinationPressure])
  @@index([systemicConcentration])
  @@index([resilienceStrength])
  @@index([createdAt])
  @@map("relational_macro_observatory_governance_snapshots")
}

model RelationalMacroObservatoryGovernanceEvent {
  id                    String                            @id @default(uuid()) @db.Uuid
  relationshipId        String                            @db.Uuid
  macroObservatoryGovernanceNodeId String?                      @db.Uuid
  eventType             RelationalMacroObservatoryGovernanceEventType
  actorOrganizationId   String                            @db.Uuid
  diagnostics           Json?
  metadata              Json?
  createdAt             DateTime                          @default(now())

  relationship             Relationship                  @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  macroObservatoryGovernanceNode RelationalMacroObservatoryGovernanceNode? @relation("MacroObservatoryGovernanceEventNode", fields: [macroObservatoryGovernanceNodeId], references: [id], onDelete: SetNull)

  @@index([relationshipId])
  @@index([macroObservatoryGovernanceNodeId])
  @@index([eventType])
  @@index([createdAt])
  @@map("relational_macro_observatory_governance_events")
}

