  dormantRelationshipRatio            Float                         @default(0)
  unresolvedNegotiationRatio          Float                         @default(0)
  symbolicReservationReliability      Float                         @default(0)
  deliveryConsistencySignal           Float                         @default(0)
  commercialStabilitySignal           Float                         @default(0)
