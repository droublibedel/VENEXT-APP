  windowDurationHours       Int                   @default(168)
  discoverySource           String                @default("INTELLIGENCE_PLACEMENT")
  startsAt                  DateTime
  endsAt                    DateTime
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt

  sponsor      Organization                  @relation("SponsoredCampaignSponsorOrg", fields: [sponsorOrganizationId], references: [id], onDelete: Cascade)
  product      Product                       @relation(fields: [productId], references: [id], onDelete: Cascade)
  windows      SponsoredConversationWindow[]
  exposureRows SponsoredExposureAnalytics[]

  @@index([sponsorOrganizationId, active])
  @@index([productId])
  @@map("sponsored_commercial_campaigns")
}

/**
 * Instruction 20.2 — one temporary sponsored conversation window between sponsor and target orgs.
 */
model SponsoredConversationWindow {
  id                           String                            @id @default(uuid()) @db.Uuid
  campaignId                   String                            @db.Uuid
  sponsorOrganizationId        String                            @db.Uuid
  targetOrganizationId         String                            @db.Uuid
  productId                    String                            @db.Uuid
  state                        TemporaryCommercialHandshakeState @default(DISCOVERED)
  regionScope                  String?
  cityScope                    String?
  districtScope                String?
  expiresAt                    DateTime
  openedAt                     DateTime?
  lastActivityAt               DateTime?
  convertedToRelationship      Boolean                           @default(false)
  relationshipId               String?                           @db.Uuid
  temporaryConversationAllowed Boolean                           @default(true)
  sponsorBudgetSnapshot        Json                              @default("{}")
  discoverySource              String                            @default("INTELLIGENCE_PLACEMENT")
  createdAt                    DateTime                          @default(now())
  updatedAt                    DateTime                          @updatedAt

  campaign       SponsoredCommercialCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sponsor        Organization                   @relation("SponsoredWindowSponsorOrg", fields: [sponsorOrganizationId], references: [id], onDelete: Cascade)
  target         Organization                   @relation("SponsoredWindowTargetOrg", fields: [targetOrganizationId], references: [id], onDelete: Cascade)
  product        Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  relationship   Relationship?                  @relation(fields: [relationshipId], references: [id], onDelete: SetNull)
  requests       SponsoredRelationshipRequest[]
  messageThreads MessageThread[]

  @@index([campaignId, targetOrganizationId])
  @@index([expiresAt])
  @@map("sponsored_conversation_windows")
}

model SponsoredRelationshipRequest {
  id                            String                            @id @default(uuid()) @db.Uuid
  requesterOrganizationId       String                            @db.Uuid
  targetOrganizationId          String                            @db.Uuid
