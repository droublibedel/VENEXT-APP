/**
 * Instruction 20.2 — sponsor-defined discovery campaign (economic placement, not open ads).
 */
model SponsoredCommercialCampaign {
  id                        String                @id @default(uuid()) @db.Uuid
  sponsorOrganizationId     String                @db.Uuid
  productId                 String                @db.Uuid
  active                    Boolean               @default(true)
  regionScope               String?
  cityScope                 String?
  districtScope             String?
  targetActorCategory       OrganizationCategory?
  sponsorBudgetSnapshot     Json                  @default("{}")
  maxActiveWindowsPerTarget Int                   @default(3)
