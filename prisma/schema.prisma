/**
 * Instruction 20.23 — sector & market structure intelligence (analytical infrastructure, not ERP).
 */
enum RelationalSectorType {
  PRIMARY_INDUSTRY
  SECONDARY_VALUE_ADD
  DISTRIBUTION_LOGISTICS
  SERVICES
  MIXED_CROSS_SECTOR
  UNKNOWN
}

enum RelationalSectorPressureLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RelationalSectorConcentrationLevel {
  DISPERSED
  MODERATE
  CONCENTRATED
  DOMINANT
}

enum RelationalSectorSignalType {
  SECTOR_PRESSURE_ALERT
  DEPENDENCY_SPIKE
  CONCENTRATION_WARNING
  PROPAGATION_ALERT
  MARKET_FRAGILITY
  EXPANSION_READING
  SYSTEMIC_SECTOR_RISK
}

enum RelationalSectorDependencyType {
  UPSTREAM_SUPPLY
  DOWNSTREAM_DEMAND
  SHARED_INFRASTRUCTURE
  TERRITORIAL_OVERLAP
  CORRIDOR_CO_MOVEMENT
  CROSS_SECTOR_EXPOSURE
}

enum RelationalSectorEventType {
  SECTOR_NODE_MATERIALIZED
  DEPENDENCY_OBSERVED
  SIGNAL_EMITTED
  PROPAGATION_EVALUATED
  SIGNAL_ARCHIVED
  STRUCTURE_RECOMPUTED
}

enum RelationalSectorMarketStructureType {
  COMPETITIVE_FRAGMENTED
  MODERATE_OLIGOPOLY
  TIGHT_OLIGOPOLY
  MONOPSONY_RISK
  BALANCED
  UNKNOWN
}

model RelationalSectorNode {
  id                      String                              @id @default(uuid()) @db.Uuid
  relationshipId          String                              @db.Uuid
  sectorCode              String                              @unique
  sectorType              RelationalSectorType
  sectorName              String
  sectorSlug              String
  territoryCountry        String
  territoryCity           String
  marketStructureType     RelationalSectorMarketStructureType
  concentrationLevel      RelationalSectorConcentrationLevel
  pressureLevel           RelationalSectorPressureLevel
  operationalRiskScore    Int                                 @default(0)
  expansionPotentialScore Int                                 @default(0)
  fragilityScore          Int                                 @default(0)
  dependencyScore         Int                                 @default(0)
  active                  Boolean                             @default(true)
  diagnostics             Json?
  metadata                Json?
  createdAt               DateTime                            @default(now())
  updatedAt               DateTime                            @updatedAt

  relationship                Relationship                           @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  signals                     RelationalSectorSignal[]
  events                      RelationalSectorEvent[]
  outgoingDeps                RelationalSectorDependency[]           @relation("SectorDepSource")
  incomingDeps                RelationalSectorDependency[]           @relation("SectorDepTarget")
  supplyFlowNodes             RelationalSupplyFlowNode[]
  macroEconomicNodes          RelationalMacroEconomicNode[]
  continuityNodes             RelationalEconomicContinuityNode[]
  sovereigntyNodes            RelationalEconomicSovereigntyNode[]
  recoveryPlans               RelationalEconomicRecoveryPlan[]
  governanceNodes             RelationalEconomicGovernanceNode[]
  arbitrationCases            RelationalEconomicArbitrationCase[]
  stabilizationNodes          RelationalEconomicStabilizationNode[]
  monitoringNodes             RelationalEconomicMonitoringNode[]
  executiveOrchestrationNodes RelationalExecutiveOrchestrationNode[]
  institutionalReportingNodes RelationalInstitutionalReportingNode[]
  strategicIntelligenceNodes RelationalStrategicIntelligenceNode[]
  strategicCommandNodes    RelationalStrategicCommandNode[]
  executiveOperationsNodes    RelationalExecutiveOperationsNode[]
  controlRoomNodes    RelationalExecutiveControlRoomNode[]
  strategicSynthesisNodes RelationalExecutiveStrategicSynthesisNode[]
  globalExecutiveSupervisionNodes    RelationalGlobalExecutiveSupervisionNode[]
  strategicObservatoryNodes         RelationalStrategicObservatoryNode[]
  macroObservatoryGovernanceNodes         RelationalMacroObservatoryGovernanceNode[]

  @@unique([relationshipId, sectorSlug])
  @@index([relationshipId])
  @@index([sectorType])
  @@index([concentrationLevel])
  @@index([pressureLevel])
  @@index([operationalRiskScore])
  @@index([territoryCountry])
  @@index([territoryCity])
  @@map("relational_sector_nodes")
}

model RelationalSectorDependency {
  id                     String                         @id @default(uuid()) @db.Uuid
  sourceSectorId         String                         @db.Uuid
  targetSectorId         String                         @db.Uuid
  dependencyType         RelationalSectorDependencyType
  dependencyStrength     Int
  propagationProbability Float
  riskTransferScore      Int
  sharedPressureScore    Int
  diagnostics            Json?
  metadata               Json?
  createdAt              DateTime                       @default(now())

  sourceNode RelationalSectorNode @relation("SectorDepSource", fields: [sourceSectorId], references: [id], onDelete: Cascade)
  targetNode RelationalSectorNode @relation("SectorDepTarget", fields: [targetSectorId], references: [id], onDelete: Cascade)

  @@index([sourceSectorId])
  @@index([targetSectorId])
  @@map("relational_sector_dependencies")
}

model RelationalSectorSignal {
  id                   String                     @id @default(uuid()) @db.Uuid
  relationshipId       String                     @db.Uuid
  sectorNodeId         String                     @db.Uuid
  signalType           RelationalSectorSignalType
  severity             String                     @db.VarChar(16)
  title                String                     @db.VarChar(400)
  description          String                     @db.VarChar(4000)
  signalScore          Int
  propagationRisk      Int
  pressureContribution Int
  diagnostics          Json?
  metadata             Json?
  createdAt            DateTime                   @default(now())

  relationship Relationship         @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  sectorNode   RelationalSectorNode @relation(fields: [sectorNodeId], references: [id], onDelete: Cascade)

  @@index([relationshipId])
  @@index([sectorNodeId])
  @@index([signalType])
  @@map("relational_sector_signals")
}

model RelationalSectorEvent {
  id                  String                    @id @default(uuid()) @db.Uuid
  eventType           RelationalSectorEventType
  sectorNodeId        String?                   @db.Uuid
  relationshipId      String?                   @db.Uuid
  actorOrganizationId String                    @db.Uuid
  diagnostics         Json?
  metadata            Json?
  createdAt           DateTime                  @default(now())

  sectorNode   RelationalSectorNode? @relation(fields: [sectorNodeId], references: [id], onDelete: SetNull)
  relationship Relationship?         @relation(fields: [relationshipId], references: [id], onDelete: SetNull)

  @@index([sectorNodeId])
  @@index([relationshipId])
  @@index([eventType])
  @@index([createdAt])
  @@map("relational_sector_events")
}

/**
