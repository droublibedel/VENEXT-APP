// -----------------------------------------------------------------------------
// Core identity & org graph
// -----------------------------------------------------------------------------

model User {
  id                String            @id @default(uuid()) @db.Uuid
  phoneNumber       String            @unique
  phoneVerified     Boolean           @default(false)
  email             String?
  fullName          String
  avatarUrl         String?
  preferredLanguage PreferredLanguage @default(en)
  status            UserStatus        @default(PENDING_VERIFICATION)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  ownedOrganizations     Organization[]        @relation("OrgOwner")
  memberships            OrganizationMember[]
  contactSuggestions     ContactSuggestion[]
  contactSnapshots       UserContactSnapshot[]
  messagesSent           Message[]             @relation("MessageSender")
  relationalCartsCreated RelationalCart[]      @relation("RelCartCreatedBy")
  businessIdentity       UserBusinessIdentity?

  @@map("users")
}

/// VENEXT-MOBILE-ARCHI-04 — profils métier terrain (Grossiste B / Détaillant) par utilisateur.
model UserBusinessIdentity {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String?  @unique @db.Uuid
  phoneKey             String?  @unique @db.VarChar(32)
  enabledProfiles      String[] @default([])
  primaryProfile       String   @db.VarChar(32)
  currentActiveProfile String   @db.VarChar(32)
  activatedAt          DateTime?
  lastActiveProfile       String?  @db.VarChar(32)
  switchedAt           DateTime?
  switchReason         String?  @db.VarChar(64)
  source               String?
  activeProfileVersion Int      @default(1)
  lastSyncedAt         DateTime?
  deviceId             String?  @db.VarChar(64)
  lastDeviceId         String?  @db.VarChar(64)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("user_business_identities")
}

model Organization {
  id                  String                         @id @default(uuid()) @db.Uuid
  /**
   * Public 10-digit commercial network identifier — not phone, not UUID; immutable after creation.
   */
  commercialId        String                         @unique @db.VarChar(10)
  ownerUserId         String                         @db.Uuid
  displayName         String
  legalName           String?
  activityLabel       String
  actorType           OrganizationActorType
  category            OrganizationCategory
  profileImageUrl     String?
  country             String
  city                String
  commune             String?
  address             String?
  verificationStatus  OrganizationVerificationStatus @default(UNVERIFIED)
  credibilityScore    Float                          @default(0)
  /**
   * Instruction 10 — governance kill-switch (distinct from verification).
   */
  governanceSuspended Boolean                        @default(false)
  /**
   * Instruction 9 — commercial identity badges (VERIFIED, PREMIUM, …)
   */
  commercialBadges    String[]                       @default([])
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  owner User @relation("OrgOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  members                                  OrganizationMember[]
  catalogs                                 Catalog[]
  products                                 Product[]
  catalogueOwnership                       CatalogueOwnership?
  marketProjections                        ProductMarketProjection[] @relation("MarketViewer")
  productTransferHistories                 ProductTransferHistory[]  @relation("TransferTarget")
  networkCodes                             NetworkCode[]
  wallets                                  Wallet[]
  walletAccount                            WalletAccount?
  transactions                             Transaction[]                  @relation("TxnOrg")
  relationshipsReq                         Relationship[]                 @relation("RelRequester")
  relationshipsRec                         Relationship[]                 @relation("RelReceiver")
  relationshipsUp                          Relationship[]                 @relation("RelUpstream")
  relationshipsDn                          Relationship[]                 @relation("RelDownstream")
  buyerOrders                              Order[]                        @relation("OrderBuyer")
  sellerOrders                             Order[]                        @relation("OrderSeller")
  negotiationsBuy                          Negotiation[]                  @relation("NegBuyer")
  negotiationsSell                         Negotiation[]                  @relation("NegSeller")
  suggestions                              ContactSuggestion[]
  visibilityRows                           ProductVisibility[]            @relation("VisToOrg")
  economicSignals                          EconomicSignal[]
  poleConfigs                              IndustrialPoleConfig[]
  threadsAsBuyer                           MessageThread[]                @relation("ThreadBuyerOrg")
  threadsAsSeller                          MessageThread[]                @relation("ThreadSellerOrg")
  messagesFromOrg                          Message[]                      @relation("MessageOrg")
  groupBuyingInitiated                     GroupBuyingSession[]           @relation("GroupBuyingInitiator")
  sponsoredInjections                      SponsoredProductInjection[]    @relation("SponsorOrg")
  reservationIntents                       ReservationIntent[]
  logisticsShipments                       Shipment[]                     @relation("LogisticsShipmentOrg")
  sponsoredCommercialCampaignsAsSponsor    SponsoredCommercialCampaign[]  @relation("SponsoredCampaignSponsorOrg")
  sponsoredConversationWindowsAsSponsor    SponsoredConversationWindow[]  @relation("SponsoredWindowSponsorOrg")
  sponsoredConversationWindowsAsTarget     SponsoredConversationWindow[]  @relation("SponsoredWindowTargetOrg")
  sponsoredRelationshipRequestsAsRequester SponsoredRelationshipRequest[] @relation("SponsoredRelReqRequesterOrg")
  sponsoredRelationshipRequestsAsTarget    SponsoredRelationshipRequest[] @relation("SponsoredRelReqTargetOrg")
  sponsoredExposureAnalyticsRows           SponsoredExposureAnalytics[]   @relation("SponsoredExposureSponsorOrg")
  commercialTrustProfile                   CommercialTrustProfile?
  relationalCartsOwning                    RelationalCart[]               @relation("RelCartOwningOrg")
  relationalCartsAsBuyer                   RelationalCart[]               @relation("RelCartBuyerOrg")
  relationalCartsAsSeller                  RelationalCart[]               @relation("RelCartSellerOrg")

  @@index([ownerUserId])
  @@index([category, country])
  @@map("organizations")
}

model OrganizationMember {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid
  userId         String          @db.Uuid
  role           OrgMemberRole
  pole           OrgMemberPole?
  status         OrgMemberStatus @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Relationship {
  id                         String                       @id @default(uuid()) @db.Uuid
  requesterOrganizationId    String                       @db.Uuid
  receiverOrganizationId     String                       @db.Uuid
  status                     RelationshipStatus           @default(PENDING)
  source                     RelationshipSource
  /**
   * Set when status is ACCEPTED (or provisional preview during invite). Nullable while PENDING without inferred edge.
   */
  upstreamOrganizationId     String?                      @db.Uuid
  downstreamOrganizationId   String?                      @db.Uuid
  /**
   * Instruction 9 — trust / category / visibility contract
   */
  trustLevel                 Float                        @default(0.55)
  commerceCategory           String                       @default("")
  visibilityPermissions      Json                         @default("{}")
  createdAt                  DateTime                     @default(now())
  acceptedAt                 DateTime?
  rejectedAt                 DateTime?
  /**
   * Instruction 20.4 — governed corridor state (richer than Relationship.status alone).
   */
  corridorState              CommercialCorridorState      @default(INVITED)
  corridorActivatedAt        DateTime?
  corridorLastActivityAt     DateTime?
  corridorHealthScore        Int                          @default(50)
  corridorVisibilityLevel    CommercialCorridorVisibility @default(STRICT_PRIVATE)
  corridorEconomicImportance Float                        @default(0.55)
  corridorDiagnostics        Json                         @default("{}")

  requester     Organization  @relation("RelRequester", fields: [requesterOrganizationId], references: [id], onDelete: Cascade)
  receiver      Organization  @relation("RelReceiver", fields: [receiverOrganizationId], references: [id], onDelete: Cascade)
  upstreamOrg   Organization? @relation("RelUpstream", fields: [upstreamOrganizationId], references: [id], onDelete: Cascade)
  downstreamOrg Organization? @relation("RelDownstream", fields: [downstreamOrganizationId], references: [id], onDelete: Cascade)

  orders                                       Order[]
  productVisibility                            ProductVisibility[]                          @relation("VisRelationship")
  groupBuyingSessions                          GroupBuyingSession[]
  sponsoredInjections                          SponsoredProductInjection[]
  reservationIntents                           ReservationIntent[]
  shipments                                    Shipment[]
  sponsoredConversationWindows                 SponsoredConversationWindow[]
  commercialTrustSnapshots                     CommercialTrustRelationshipSnapshot[]
  commercialCorridorSignals                    CommercialCorridorSignal[]
  commercialCorridorSnapshot                   CommercialCorridorSnapshot?
  relationalCarts                              RelationalCart[]
  relationalOperationalAlerts                  RelationalOperationalAlert[]
  relationalOperationalMetrics                 RelationalOperationalMetric[]
  relationalPredictiveRiskSignals              RelationalPredictiveRiskSignal[]
  relationalOperationalDriftSnapshots          RelationalOperationalDriftSnapshot[]
  relationalOperationalRecommendations         RelationalOperationalRecommendation[]
  relationalOperationalOrchestrations          RelationalOperationalOrchestration[]
  relationalOperationalSimulations             RelationalOperationalSimulation[]
  relationalScenarioReviewBoards               RelationalScenarioReviewBoard[]
  relationalStrategicMemories                  RelationalStrategicMemory[]
  relationalEconomicSignalNodes                RelationalEconomicSignalNode[]
  relationalEconomicCommandCenterSnapshots     RelationalEconomicCommandCenterSnapshot[]
  relationalEconomicDependencyNodes            RelationalEconomicDependencyNode[]
  relationalEconomicPressureEvents             RelationalEconomicPressureEvent[]
  relationalGeoEconomicZoneCorridors           RelationalGeoEconomicZoneCorridor[]
  relationalGeoEconomicEvents                  RelationalGeoEconomicEvent[]
  relationalSectorNodes                        RelationalSectorNode[]
  relationalSectorEvents                       RelationalSectorEvent[]
  relationalSectorSignals                      RelationalSectorSignal[]
  relationalSupplyFlowNodes                    RelationalSupplyFlowNode[]
  relationalSupplyFlowSignals                  RelationalSupplyFlowSignal[]
  relationalSupplyFlowEvents                   RelationalSupplyFlowEvent[]
  relationalMacroEconomicNodes                 RelationalMacroEconomicNode[]
  relationalMacroEconomicPressureSignals       RelationalMacroEconomicPressureSignal[]
  relationalMacroEconomicResilienceSnapshots   RelationalMacroEconomicResilienceSnapshot[]
  relationalMacroEconomicEvents                RelationalMacroEconomicEvent[]
  relationalEconomicContinuityNodes            RelationalEconomicContinuityNode[]
  relationalEconomicContinuitySignals          RelationalEconomicContinuitySignal[]
  relationalEconomicContinuitySnapshots        RelationalEconomicContinuitySnapshot[]
  relationalEconomicContinuityEvents           RelationalEconomicContinuityEvent[]
  relationalEconomicSovereigntyNodes           RelationalEconomicSovereigntyNode[]
  relationalEconomicSovereigntySignals         RelationalEconomicSovereigntySignal[]
  relationalEconomicSovereigntySnapshots       RelationalEconomicSovereigntySnapshot[]
  relationalEconomicSovereigntyEvents          RelationalEconomicSovereigntyEvent[]
  relationalEconomicRecoveryPlans              RelationalEconomicRecoveryPlan[]
  relationalEconomicRecoverySignals            RelationalEconomicRecoverySignal[]
  relationalEconomicRecoverySnapshots          RelationalEconomicRecoverySnapshot[]
  relationalEconomicRecoveryEvents             RelationalEconomicRecoveryEvent[]
  relationalEconomicGovernanceNodes            RelationalEconomicGovernanceNode[]
  relationalEconomicGovernanceCoordinations    RelationalEconomicGovernanceCoordination[]
  relationalEconomicGovernanceConflicts        RelationalEconomicGovernanceConflict[]
  relationalEconomicGovernanceSnapshots        RelationalEconomicGovernanceSnapshot[]
  relationalEconomicGovernanceEvents           RelationalEconomicGovernanceEvent[]
  relationalEconomicArbitrationCases           RelationalEconomicArbitrationCase[]
  relationalEconomicArbitrationScenarios       RelationalEconomicArbitrationScenario[]
  relationalEconomicArbitrationDecisions       RelationalEconomicArbitrationDecision[]
  relationalEconomicArbitrationSnapshots       RelationalEconomicArbitrationSnapshot[]
