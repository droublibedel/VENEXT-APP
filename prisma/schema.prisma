/**
 * Instruction 15A — lightweight shipment row (order proxy or future edge ingest).
 */
model Shipment {
  id                   String               @id @default(uuid()) @db.Uuid
  organizationId       String               @db.Uuid
  orderId              String?              @unique @db.Uuid
  relationshipId       String?              @db.Uuid
  routeCode            String?
  originTerritory      String
  destinationTerritory String
  shipmentStatus       ShipmentStatus       @default(PLANNED)
  healthStatus         ShipmentHealthStatus @default(HEALTHY)
  plannedDepartureAt   DateTime?
  actualDepartureAt    DateTime?
  plannedArrivalAt     DateTime?
  actualArrivalAt      DateTime?
  carrierLabel         String?
  vehicleRef           String?
  trackingMode         ShipmentTrackingMode @default(NONE)
  metadata             Json                 @default("{}")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  organization Organization  @relation("LogisticsShipmentOrg", fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  relationship Relationship? @relation(fields: [relationshipId], references: [id], onDelete: SetNull)

  @@index([organizationId, shipmentStatus])
  @@index([organizationId, updatedAt])
  @@map("shipments")
}

model OrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @db.Uuid
  productId       String   @db.Uuid
  quantity        Decimal  @db.Decimal(18, 4)
  unitPrice       Decimal  @db.Decimal(18, 4)
  negotiatedPrice Decimal? @db.Decimal(18, 4)
  subtotal        Decimal  @db.Decimal(24, 6)
  createdAt       DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@map("order_items")
}

model Negotiation {
  id                       String            @id @default(uuid()) @db.Uuid
  productId                String            @db.Uuid
  buyerOrganizationId      String            @db.Uuid
  sellerOrganizationId     String            @db.Uuid
  status                   NegotiationStatus @default(OPEN)
  proposedQuantity         Decimal?          @db.Decimal(18, 4)
  proposedPrice            Decimal?          @db.Decimal(18, 4)
  acceptedQuantity         Decimal?          @db.Decimal(18, 4)
  acceptedPrice            Decimal?          @db.Decimal(18, 4)
  /**
   * Instruction 8 — operational payment mode negotiation
   */
  proposedPaymentMode      PaymentMode?
  acceptedPaymentMode      PaymentMode?
  paymentConstraints       Json              @default("{}")
  /**
   * Instruction 20.1A — conversational human-confirmed draft (metadata only; does not replace Negotiation.status).
   */
  negotiationDraftMetadata Json              @default("{}")
  expiresAt                DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer   Organization @relation("NegBuyer", fields: [buyerOrganizationId], references: [id], onDelete: Cascade)
  seller  Organization @relation("NegSeller", fields: [sellerOrganizationId], references: [id], onDelete: Cascade)

  threads            MessageThread[]
  reservationIntents ReservationIntent[]
  relationalCarts    RelationalCart[]

  @@index([productId, buyerOrganizationId, sellerOrganizationId])
  @@map("negotiations")
}

/**
 * Instruction 20.5 — private corridor-scoped relational preparation cart (not public checkout).
 */
model RelationalCart {
  id                              String                   @id @default(uuid()) @db.Uuid
  organizationId                  String                   @db.Uuid
  buyerOrganizationId             String                   @db.Uuid
  sellerOrganizationId            String                   @db.Uuid
  relationshipId                  String                   @db.Uuid
  negotiationId                   String?                  @db.Uuid
  threadId                        String?                  @db.Uuid
  sourceType                      RelationalCartSourceType
  status                          RelationalCartStatus     @default(DRAFT)
  corridorStateAtCreation         CommercialCorridorState
  corridorGovernanceValidated     Boolean                  @default(false)
  corridorOperationalWarnings     Json                     @default("[]")
  corridorPolicySource            String                   @default("RelationshipGovernancePolicyService.assertCorridorOperational")
  commercialTrustBand             String?
  requiresBuyerSellerConfirmation Boolean                  @default(false)
  conversionBlockedReason         String?
  cartConvertibleToOrder          Boolean                  @default(true)
  createdByUserId                 String                   @db.Uuid
  expiresAt                       DateTime?
  convertedOrderId                String?                  @unique @db.Uuid
  metadata                        Json                     @default("{}")
  /**
   * Instruction 20.7 — buyer corridor confirmation (not payment).
   */
  buyerConfirmedAt                DateTime?
  sellerConfirmedAt               DateTime?
  buyerConfirmedByUserId          String?                  @db.Uuid
  sellerConfirmedByUserId         String?                  @db.Uuid
  lockedAt                        DateTime?
  lockedByUserId                  String?                  @db.Uuid
  rejectedAt                      DateTime?
  rejectedByUserId                String?                  @db.Uuid
  rejectionReason                 String?
  confirmationDiagnostics         Json                     @default("{}")
  lockDiagnostics                 Json                     @default("{}")
  createdAt                       DateTime                 @default(now())
  updatedAt                       DateTime                 @updatedAt

  organization       Organization         @relation("RelCartOwningOrg", fields: [organizationId], references: [id], onDelete: Cascade)
  buyerOrganization  Organization         @relation("RelCartBuyerOrg", fields: [buyerOrganizationId], references: [id], onDelete: Cascade)
  sellerOrganization Organization         @relation("RelCartSellerOrg", fields: [sellerOrganizationId], references: [id], onDelete: Cascade)
  relationship       Relationship         @relation(fields: [relationshipId], references: [id], onDelete: Restrict)
  negotiation        Negotiation?         @relation(fields: [negotiationId], references: [id], onDelete: SetNull)
  thread             MessageThread?       @relation(fields: [threadId], references: [id], onDelete: SetNull)
  createdByUser      User                 @relation("RelCartCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  convertedOrder     Order?               @relation("RelCartConvertedOrder", fields: [convertedOrderId], references: [id], onDelete: SetNull)
  items              RelationalCartItem[]

  @@index([relationshipId, status])
  @@index([buyerOrganizationId, updatedAt])
  @@index([sellerOrganizationId, updatedAt])
  @@index([negotiationId])
  @@index([threadId])
  @@map("relational_carts")
}

model RelationalCartItem {
  id                    String                             @id @default(uuid()) @db.Uuid
  cartId                String                             @db.Uuid
  productId             String                             @db.Uuid
  catalogId             String?                            @db.Uuid
  quantity              Decimal                            @db.Decimal(18, 4)
  unit                  String
  symbolicStockStatus   String
  sourceMessageId       String?                            @db.Uuid
  sourceNegotiationId   String?                            @db.Uuid
  sourceDraftRevisionId String?
  lineValidationStatus  RelationalCartLineValidationStatus @default(VALIDATED)
  metadata              Json                               @default("{}")
  createdAt             DateTime                           @default(now())
  updatedAt             DateTime                           @updatedAt

  cart    RelationalCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([cartId])
  @@index([productId])
  @@map("relational_cart_items")
}

// -----------------------------------------------------------------------------
// Messaging (commerce-contextual, not chat clone)
// -----------------------------------------------------------------------------

model MessageThread {
  id                            String     @id @default(uuid()) @db.Uuid
  threadType                    ThreadType
  productId                     String?    @db.Uuid
  orderId                       String?    @db.Uuid
  negotiationId                 String?    @db.Uuid
  buyerOrganizationId           String?    @db.Uuid
  sellerOrganizationId          String?    @db.Uuid
  /**
   * Instruction 20.2 — links temporary sponsored corridor to messaging thread.
   */
  sponsoredConversationWindowId String?    @db.Uuid
  /**
   * Instruction 20.2 — UI / API diagnostics (JSON), not ERP payload.
   */
  sponsoredDiscoveryMetadata    Json       @default("{}")
  /**
   * Instruction 20.1 — conversational order draft + negotiation heuristics (JSON envelope, not ERP form).
   */
  conversationalOrderDraft      Json       @default("{}")
  createdAt                     DateTime   @default(now())
  updatedAt                     DateTime   @updatedAt

  product                     Product?                     @relation(fields: [productId], references: [id], onDelete: SetNull)
  order                       Order?                       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  negotiation                 Negotiation?                 @relation(fields: [negotiationId], references: [id], onDelete: SetNull)
  buyerOrg                    Organization?                @relation("ThreadBuyerOrg", fields: [buyerOrganizationId], references: [id], onDelete: SetNull)
  sellerOrg                   Organization?                @relation("ThreadSellerOrg", fields: [sellerOrganizationId], references: [id], onDelete: SetNull)
  sponsoredConversationWindow SponsoredConversationWindow? @relation(fields: [sponsoredConversationWindowId], references: [id], onDelete: SetNull)

  messages                Message[]
  pendingOutboundMessages PendingOutboundMessage[]
  relationalCarts         RelationalCart[]

  @@index([productId])
  @@index([negotiationId])
  @@index([sponsoredConversationWindowId])
  @@map("message_threads")
}

model Message {
  id                   String               @id @default(uuid()) @db.Uuid
  threadId             String               @db.Uuid
  senderUserId         String               @db.Uuid
  senderOrganizationId String               @db.Uuid
  messageType          MessageType
  content              String?
  mediaUrls            String[]             @default([])
  voiceUrl             String?
  structuredEvent      Json?
  deliveryState        MessageDeliveryState @default(SENT)
  createdAt            DateTime             @default(now())
  readAt               DateTime?

  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User          @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  senderOrg Organization  @relation("MessageOrg", fields: [senderOrganizationId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("messages")
}

/**
 * Unstable network — outbound queue (Instruction 7 §10).
 */
model PendingOutboundMessage {
  id            String               @id @default(uuid()) @db.Uuid
  threadId      String               @db.Uuid
  payload       Json
  deliveryState MessageDeliveryState @default(SENDING)
  attemptCount  Int                  @default(0)
  lastError     String               @default("")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([deliveryState, createdAt])
  @@map("pending_outbound_messages")
}

// -----------------------------------------------------------------------------
// Wallet & ledger
// -----------------------------------------------------------------------------

model Wallet {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  balance        Decimal      @default(0) @db.Decimal(24, 6)
  currency       String
  status         WalletStatus @default(ACTIVE)
  qrPayload      String       @default("")
  nfcEnabled     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

