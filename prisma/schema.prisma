/**
 * Instruction 20.4 — persisted corridor intelligence signals (unique per relationship + type).
 */
model CommercialCorridorSignal {
  id             String                       @id @default(uuid()) @db.Uuid
  relationshipId String                       @db.Uuid
  signalType     CommercialCorridorSignalType
  signalStrength Float
  explanation    String                       @db.VarChar(4000)
  metadata       Json                         @default("{}")
  heuristicOnly  Boolean                      @default(true)
  sourceCounters Json                         @default("{}")
  computedAt     DateTime                     @default(now())

  relationship Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  @@unique([relationshipId, signalType])
  @@index([relationshipId])
  @@map("commercial_corridor_signals")
}

/**
 * Instruction 20.4 — bounded recompute cache per corridor (avoid full recompute every read).
 */
model CommercialCorridorSnapshot {
  id             String                  @id @default(uuid()) @db.Uuid
  relationshipId String                  @unique @db.Uuid
  healthScore    Int
  riskBand       String                  @db.VarChar(16)
