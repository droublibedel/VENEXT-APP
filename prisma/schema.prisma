  relationalEconomicStabilizationNodes         RelationalEconomicStabilizationNode[]
  relationalEconomicStabilizationSignals       RelationalEconomicStabilizationSignal[]
  relationalEconomicStabilizationDependencies  RelationalEconomicStabilizationDependency[]
  relationalEconomicStabilizationSnapshots     RelationalEconomicStabilizationSnapshot[]
