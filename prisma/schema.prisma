enum BackofficeErrorTreatmentStatus {
  NEW
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  IGNORED
}

enum BackofficeJourneyStatus {
  STARTED
  IN_PROGRESS
  COMPLETED
  ABANDONED
  FAILED
  BLOCKED
}

enum BackofficeSupportPriority {
  LOW
  NORMAL
  IMPORTANT
  URGENT
}

model BackofficeOperatorSession {
  id         String   @id @default(uuid()) @db.Uuid
  email      String
  operatorId String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([email])
  @@map("backoffice_operator_sessions")
}

model BackofficeOtpChallenge {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@map("backoffice_otp_challenges")
}

model BackofficeAuthAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  kind      String
  success   Boolean  @default(false)
  ipHint    String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([kind, createdAt])
  @@map("backoffice_auth_attempts")
}

model BackofficeTrustedDevice {
  id        String    @id @default(uuid()) @db.Uuid
  email     String
  deviceKey String
  trustedAt DateTime  @default(now())
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@unique([email, deviceKey])
  @@map("backoffice_trusted_devices")
}

model BackofficeLiveEventRetryRecord {
  id          String   @id @default(uuid()) @db.Uuid
  kind        String
  payload     Json
  attempts    Int      @default(0)
  nextRetryAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([nextRetryAt, attempts])
  @@map("backoffice_live_event_retries")
}

model BackofficeHealthSnapshotRecord {
  id         String   @id @default(uuid()) @db.Uuid
  components Json
  checkedAt  DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([checkedAt])
  @@map("backoffice_health_snapshots")
}

model BackofficeErrorEventRecord {
  id                 String                          @id @default(uuid()) @db.Uuid
  occurredAt         DateTime                        @default(now())
  userId             String?
  userPhone          String?
  userEmail          String?
  actorId            String?
  actorRole          String?
  application        String
  screen             String?
  action             String?
  userFacingMessage  String
  technicalMessage   String
  internalStack      String?
  errorType          String
  severity           String
  treatmentStatus    BackofficeErrorTreatmentStatus  @default(NEW)
  commercialContext  Json                            @default("{}")
  device             String?
  userAgent          String?
  networkHint        String?
  routeOrApi         String?
  module             String?
  journeyId          String?                         @db.Uuid
  archivedAt         DateTime?
  archivedReason     String?
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt

  @@index([occurredAt])
  @@index([treatmentStatus, occurredAt])
  @@index([application, occurredAt])
  @@index([journeyId])
  @@map("backoffice_error_events")
}

model BackofficeJourneyInstanceRecord {
  journeyId          String                 @id @default(uuid()) @db.Uuid
  journeyKey         String
  actorId            String
  actorRole          String
  application        String
  startedAt          DateTime
  lastStepAt         DateTime
  completedAt        DateTime?
  currentStep        String
  expectedNextStep   String?
  status             BackofficeJourneyStatus
  failureReason      String?
  linkedErrorEventId String?                @db.Uuid
  userId             String?
  userPhone          String?
  userEmail          String?
  retryCount         Int                    @default(0)
  archivedAt         DateTime?
  archivedReason     String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([status, lastStepAt])
  @@index([journeyKey, status])
  @@map("backoffice_journey_instances")
}

model BackofficeSupportTicketRecord {
  id                 String                   @id @default(uuid()) @db.Uuid
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  priority           BackofficeSupportPriority
  source             String
  status             String
  title              String
  summary            String
  userId             String?
  userPhone          String?
  enterpriseId       String?
  linkedErrorEventId String?                  @db.Uuid
  linkedJourneyId    String?                  @db.Uuid
  assignee           String?
  note               String?
  suggestion         String?
  archivedAt         DateTime?
  archivedReason     String?

  @@index([status, priority])
  @@map("backoffice_support_tickets")
}

enum BackofficeStreamEventKind {
  ERROR_EVENT
  JOURNEY_EVENT
  SUPPORT_EVENT
  GOVERNANCE_EVENT
  SECURITY_EVENT
  HEALTH_EVENT
}

model BackofficePlatformEventRecord {
